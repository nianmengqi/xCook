# xCook 环境配置示例
# 复制此文件为 .env 后修改配置

# ==================== 基础配置 ====================

# 服务端口（宿主机映射端口）
PORT=3000

# ==================== 安全配置 ====================

# JWT 密钥（留空则自动生成，建议手动设置一个复杂的密钥）
# 生成命令: openssl rand -hex 64
JWT_SECRET=

# 管理员密码
ADMIN_PASSWORD=xcook123456

# ==================== 跨域配置 ====================

# 允许的跨域来源（多个用逗号分隔，设为 * 允许所有）
CORS_ORIGINS=*

# ==================== 数据持久化 ====================

# 数据目录（容器内）
DATA_DIR=/app/server/data
UPLOAD_DIR=/app/server/uploads
